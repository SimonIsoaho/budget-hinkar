# Project URL: Supabase → Project Settings → Data API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Publishable key (INTE secret key): Supabase → Project Settings → API Keys → Publishable key
# Börjar med sb_publishable_...
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Apple signing (development builds on physical device)
# Hitta Team ID: Xcode → Settings → Accounts → [ditt konto] → Team ID
APPLE_TEAM_ID=
